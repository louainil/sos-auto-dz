PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/sos-auto-dz

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_in_production
CSRF_SECRET=change_this_to_a_different_long_random_secret

# CORS — required in production; in development all localhost origins are allowed
FRONTEND_URL=http://localhost:3000

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP (password reset / verification emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="SOS Auto DZ <your_email@gmail.com>"
